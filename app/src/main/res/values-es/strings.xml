    <string name="onboarding_welcome_title">Bienvenido a Photos for Proton</string>
    <string name="onboarding_welcome_subtitle">Tus fotos y videos, cifrados de extremo a extremo en Proton Drive. Configuremos algunas preferencias para que la app se adapte a ti.</string>

    <string name="onboarding_backup_title">¿Qué hay que respaldar?</string>
    <string name="onboarding_backup_subtitle">Lo puedes cambiar cuando quieras desde Ajustes.</string>
    <string name="onboarding_backup_everything">Respaldar todo</string>
    <string name="onboarding_backup_everything_desc">Todas las fotos y videos del dispositivo, salvo las carpetas que excluyas después.</string>
    <string name="onboarding_backup_folders">Elegir carpetas concretas</string>
    <string name="onboarding_backup_folders_desc">Selecciona carpetas en Ajustes. No se sube nada hasta que elijas.</string>
    <string name="onboarding_backup_nothing">Nada por ahora</string>
    <string name="onboarding_backup_nothing_desc">Explora lo que ya tienes en Proton Drive sin subir nuevas fotos.</string>

    <string name="onboarding_privacy_title">Controles de privacidad</string>
    <string name="onboarding_privacy_subtitle">Decide cómo viajan tus fotos del dispositivo a Drive. Todo va cifrado por encima de esto.</string>
    <string name="onboarding_privacy_strip">Quitar metadatos al subir</string>
    <string name="onboarding_privacy_strip_desc">Elimina coordenadas GPS y datos de cámara de las fotos antes de subirlas. Recomendado.</string>
    <string name="onboarding_privacy_rename">Renombrar a fecha de captura</string>
    <string name="onboarding_privacy_rename_desc">Sube los archivos como 2026-05-30_14-32-08.jpg en lugar de IMG_2841.jpg. El archivo del dispositivo no cambia.</string>
    <string name="onboarding_privacy_delete">Quitar del dispositivo tras respaldar</string>
    <string name="onboarding_privacy_delete_desc">Cuando la foto esté a salvo en Drive, quítala del dispositivo para liberar espacio. Otras apps de galería dejan de verla.</string>

    <string name="onboarding_notif_title">Mantente al tanto</string>
    <string name="onboarding_notif_subtitle">Permite notificaciones para ver el progreso de la copia y las solicitudes de limpieza, incluso con la app cerrada.</string>

    <string name="onboarding_photos_title">Acceso a tus fotos</string>
    <string name="onboarding_photos_subtitle">Necesitamos permiso de lectura de tus fotos y videos para cifrarlos y respaldarlos en Drive.</string>

    <string name="onboarding_manage_media_title">Gestionar medios</string>
    <string name="onboarding_manage_media_subtitle">Muy recomendado. Permite a la app editar, eliminar y renombrar fotos y videos del dispositivo sin un diálogo del sistema cada vez — se usa para editar en la app, guardar al dispositivo, la papelera y Eliminar tras respaldar. Toca para abrir los ajustes del sistema.</string>
    <string name="onboarding_folders_include_title">Carpetas a respaldar</string>
    <string name="onboarding_folders_include_subtitle">Elige qué carpetas subir a Drive. El resto se queda solo en este dispositivo.</string>
    <string name="onboarding_folders_exclude_title">Carpetas a omitir</string>
    <string name="onboarding_folders_exclude_subtitle">Marca las carpetas que NO quieres subir. Lo demás se respalda automáticamente.</string>
    <string name="onboarding_folders_needs_perm">Concede acceso a las fotos primero para ver tus carpetas.</string>
    <string name="onboarding_folders_empty">No se encontraron carpetas de fotos en este dispositivo.</string>

    <string name="onboarding_about_title">Cliente independiente de terceros</string>
    <string name="onboarding_about_subtitle">Hecho por una sola persona. Sin relación con Proton AG. Código abierto, licencia GPL, sin telemetría propia.</string>
