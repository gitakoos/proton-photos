<?xml version="1.0" encoding="utf-8"?>
<!--
    PlayerView on a TextureView surface so Compose's graphicsLayer pinch-zoom
    scales the rendered frames (the default SurfaceView lives on a separate
    compositor layer and ignores parent transforms). resize_mode="fit" wraps the
    surface in an AspectRatioFrameLayout that letterboxes the video, preserving
    its aspect ratio instead of stretching to fill. The app's own pill drives
    playback, so the built-in controller stays off.
-->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    app:surface_type="texture_view"
    app:use_controller="false"
    app:resize_mode="fit" />
