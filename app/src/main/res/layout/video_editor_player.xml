<?xml version="1.0" encoding="utf-8"?>
<!--
    PlayerView pinned to a TextureView surface so Compose's graphicsLayer rotation
    propagates to the rendered video frames. The default SurfaceView is rendered
    on a separate compositor layer and ignores parent transforms, which left the
    canvas rotating while the video stayed put. resize_mode="fit" lets the
    composable's BoxWithConstraints sizing drive the aspect.
-->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:use_controller="false"
    app:show_buffering="never"
    app:resize_mode="fit" />
