    <string name="onboarding_welcome_title">Welcome to Photos for Proton</string>
    <string name="onboarding_welcome_subtitle">Your photos and videos, end-to-end encrypted on Proton Drive. Let\'s set up a few preferences so the app fits how you want to use it.</string>

    <string name="onboarding_backup_title">What should we back up?</string>
    <string name="onboarding_backup_subtitle">You can change this any time in Settings.</string>
    <string name="onboarding_backup_everything">Back up everything</string>
    <string name="onboarding_backup_everything_desc">All photos and videos on your device, with any folders you exclude later.</string>
    <string name="onboarding_backup_folders">Choose specific folders</string>
    <string name="onboarding_backup_folders_desc">Pick which folders to back up from Settings. Nothing uploads until you choose.</string>
    <string name="onboarding_backup_nothing">Nothing for now</string>
    <string name="onboarding_backup_nothing_desc">Browse what\'s already on Proton Drive without backing up new photos.</string>

    <string name="onboarding_privacy_title">Privacy controls</string>
    <string name="onboarding_privacy_subtitle">Choose how your photos travel from device to Drive. Everything is encrypted on top of these.</string>
    <string name="onboarding_privacy_strip">Strip metadata on upload</string>
    <string name="onboarding_privacy_strip_desc">Remove GPS coordinates and camera details from photos before they reach the cloud. Recommended.</string>
    <string name="onboarding_privacy_rename">Rename to capture date</string>
    <string name="onboarding_privacy_rename_desc">Upload files as 2026-05-30_14-32-08.jpg instead of IMG_2841.jpg. The on-device file stays as it is.</string>
    <string name="onboarding_privacy_delete">Remove from device after backup</string>
    <string name="onboarding_privacy_delete_desc">Once a photo is safely on Drive, take it off this device to save space. Other gallery apps stop seeing it.</string>

    <string name="onboarding_notif_title">Stay informed</string>
    <string name="onboarding_notif_subtitle">Allow notifications so you can see backup progress and cleanup prompts, even when the app is closed.</string>

    <string name="onboarding_photos_title">Access your photos</string>
    <string name="onboarding_photos_subtitle">We need read access to your photos and videos so we can encrypt them and back them up to Drive.</string>

    <string name="onboarding_manage_media_title">Manage media</string>
    <string name="onboarding_manage_media_subtitle">Strongly recommended. Lets the app edit, delete and rename photos and videos on your device without a system confirmation dialog every single time — used for in app editing, save back to device, the trash flow, and Delete after backup. Tap to open system settings.</string>
    <string name="onboarding_folders_include_title">Folders to back up</string>
    <string name="onboarding_folders_include_subtitle">Pick which folders should be uploaded to Drive. Items in other folders stay on this device only.</string>
    <string name="onboarding_folders_exclude_title">Folders to skip</string>
    <string name="onboarding_folders_exclude_subtitle">Tick folders you do NOT want uploaded. Anything else gets backed up automatically.</string>
    <string name="onboarding_folders_needs_perm">Allow access to photos first to see your folders.</string>
    <string name="onboarding_folders_empty">No photo folders found on this device.</string>

    <string name="onboarding_about_title">Independent third party client</string>
    <string name="onboarding_about_subtitle">Made by one developer. Not affiliated with Proton AG. Source available, GPL licensed, no telemetry of our own.</string>
    <string name="onboarding_about_author_subtitle">Personal site of the developer.</string>
    <string name="onboarding_about_github_subtitle">Full source code on GitHub.</string>
    <string name="onboarding_about_license_title">GPL 3.0 license</string>
    <string name="onboarding_about_license_subtitle">Free software. You can read, modify, and redistribute the source.</string>
    <string name="onboarding_about_disclaimer">Unofficial third party app. Talks to Proton Drive through the public API. Not endorsed by or affiliated with Proton AG.</string>

    <string name="onboarding_appearance_title">Make it yours</string>
    <string name="onboarding_appearance_subtitle">Pick theme, accent color and language. All adjustable later from Settings.</string>

    <string name="onboarding_lock_title">App lock</string>
    <string name="onboarding_lock_subtitle">Use biometrics or device credentials to unlock the app each time it returns to the foreground.</string>
    <string name="onboarding_lock_enable">Enable app lock</string>
    <string name="onboarding_lock_enable_desc">Asks for biometrics or device PIN every time the app opens or returns from the background.</string>
    <string name="onboarding_lock_timeout_label">Re-lock after</string>

    <string name="onboarding_done_title">You\'re all set</string>
    <string name="onboarding_done_subtitle">Your settings are saved. Anything here is adjustable from the Settings page later.</string>

