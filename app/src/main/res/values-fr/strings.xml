    <string name="onboarding_welcome_title">Bienvenue dans Photos for Proton</string>
    <string name="onboarding_welcome_subtitle">Vos photos et vidéos, chiffrées de bout en bout sur Proton Drive. Configurons quelques préférences pour que l\'app vous ressemble.</string>

    <string name="onboarding_backup_title">Que faut-il sauvegarder ?</string>
    <string name="onboarding_backup_subtitle">Modifiable à tout moment dans les paramètres.</string>
    <string name="onboarding_backup_everything">Tout sauvegarder</string>
    <string name="onboarding_backup_everything_desc">Toutes les photos et vidéos de l\'appareil, sauf les dossiers que vous exclurez plus tard.</string>
    <string name="onboarding_backup_folders">Choisir des dossiers</string>
    <string name="onboarding_backup_folders_desc">Sélectionnez les dossiers dans les paramètres. Rien ne sera téléchargé tant que vous n\'aurez pas choisi.</string>
    <string name="onboarding_backup_nothing">Rien pour l\'instant</string>
    <string name="onboarding_backup_nothing_desc">Parcourez ce qui est déjà sur Proton Drive sans sauvegarder de nouvelles photos.</string>

    <string name="onboarding_privacy_title">Contrôles de confidentialité</string>
    <string name="onboarding_privacy_subtitle">Choisissez comment vos photos passent de l\'appareil à Drive. Tout est chiffré par dessus.</string>
    <string name="onboarding_privacy_strip">Supprimer les métadonnées au téléchargement</string>
    <string name="onboarding_privacy_strip_desc">Supprime coordonnées GPS et détails de l\'appareil photo avant le cloud. Recommandé.</string>
    <string name="onboarding_privacy_rename">Renommer avec la date de prise</string>
    <string name="onboarding_privacy_rename_desc">Téléchargez les fichiers comme 2026-05-30_14-32-08.jpg au lieu de IMG_2841.jpg. Le fichier sur l\'appareil ne change pas.</string>
    <string name="onboarding_privacy_delete">Retirer de l\'appareil après sauvegarde</string>
    <string name="onboarding_privacy_delete_desc">Une fois la photo en sécurité sur Drive, retirez la de l\'appareil pour gagner de l\'espace. Les autres apps de galerie ne la verront plus.</string>

    <string name="onboarding_notif_title">Restez informé</string>
    <string name="onboarding_notif_subtitle">Autorisez les notifications pour voir la progression des sauvegardes et les demandes de nettoyage, même app fermée.</string>

    <string name="onboarding_photos_title">Accès à vos photos</string>
    <string name="onboarding_photos_subtitle">Nous avons besoin d\'un accès en lecture à vos photos et vidéos pour les chiffrer et les sauvegarder sur Drive.</string>

    <string name="onboarding_manage_media_title">Gérer les médias</string>
    <string name="onboarding_manage_media_subtitle">Fortement recommandé. Permet à l\'app de modifier, supprimer et renommer photos et vidéos sans dialogue système à chaque fois — utilisé pour la retouche dans l\'app, l\'enregistrement sur l\'appareil, la corbeille et Retirer après sauvegarde. Touchez pour ouvrir les paramètres système.</string>
    <string name="onboarding_folders_include_title">Dossiers à sauvegarder</string>
    <string name="onboarding_folders_include_subtitle">Choisissez quels dossiers téléverser sur Drive. Les autres restent uniquement sur cet appareil.</string>
    <string name="onboarding_folders_exclude_title">Dossiers à exclure</string>
    <string name="onboarding_folders_exclude_subtitle">Cochez les dossiers que vous NE voulez pas téléverser. Tout le reste est sauvegardé automatiquement.</string>
    <string name="onboarding_folders_needs_perm">Autorisez d\'abord l\'accès aux photos pour voir vos dossiers.</string>
    <string name="onboarding_folders_empty">Aucun dossier photo trouvé sur cet appareil.</string>

    <string name="onboarding_about_title">Client tiers indépendant</string>
    <string name="onboarding_about_subtitle">Fait par un seul développeur. Sans lien avec Proton AG. Code source ouvert, sous licence GPL, aucune télémétrie de notre côté.</string>
    <string name="onboarding_about_author_subtitle">Site personnel du développeur.</string>
